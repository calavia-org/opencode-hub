{
  "stack": "java",
  "detect": [
    "pom.xml",
    "build.gradle",
    "build.gradle.kts"
  ],
  "bootstrap": {
    "install": [
      "./mvnw clean install",
      "./gradlew build"
    ],
    "run": [
      "./mvnw test",
      "./gradlew test"
    ]
  },
  "reviewFocus": [
    "package structure",
    "SOLID design",
    "null safety",
    "exception handling",
    "thread safety",
    "memory usage",
    "test coverage"
  ],
  "refactorFocus": [
    "extract services",
    "reduce god classes",
    "remove duplication",
    "clarify interfaces"
  ],
  "performanceFocus": [
    "collections usage",
    "stream misuse",
    "object churn",
    "blocking calls"
  ]
}

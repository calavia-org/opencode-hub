{
  "version": "1.0",
  "description": "Path configuration for Calavia OpenCode Hub - inherits from OpenAgents Control",
  "context_root": ".opencode/context",
  "local_context": {
    "core": ".opencode/context/core",
    "openagents-repo": ".opencode/context/openagents-repo",
    "project-intelligence": ".opencode/context/project-intelligence",
    "project": ".opencode/context/project",
    "development": ".opencode/context/development",
    "ui": ".opencode/context/ui"
  },
  "context_discovery": {
    "method": "ContextScout",
    "auto_discover": true,
    "include_patterns": ["*.md"],
    "exclude_patterns": ["node_modules/**", ".git/**"]
  }
}

{
  "builds": [
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    },
    {
      "source": "/agents/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown"
        }
      ]
    },
    {
      "source": "/modes/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown"
        }
      ]
    },
    {
      "source": "/skills/(.*)/SKILL.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown"
        }
      ]
    },
    {
      "source": "/commands/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown"
        }
      ]
    },
    {
      "source": "/SPEC.template.md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/markdown"
        }
      ]
    },
    {
      "source": "/(.*)\\.(md|yml|yaml|txt)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ]
}